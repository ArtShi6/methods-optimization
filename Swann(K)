#include <iostream>
#include <cmath>
#include <functional>
#include <vector>

using namespace std;

bool sven_algorithm(const function<double(double)>& func, double x0, double t, double& a, double& b) {
    //Шаг 1
    if (t <= 0) {
        cerr << "Ошибка: шаг t должен быть положительным." << endl;
        return false;
    }
    double k = 0;
    double delta;
    double x_prev, x_cur, x_next;
    double f_prev, f_cur, f_next;
    //Шаг 2
    double f_left = func(x0 - t);
    double f_mid = func(x0);
    double f_right = func(x0 + t);

    //Шаг 3.а)
    if (f_left >= f_mid && f_mid <= f_right) {
        cout << "Нашли интервал, поздравляю!" << endl;
        a = x0 - t;
        b = x0 + t;
        return true;
    }
    //Шаг 3.б)
    else if (f_left <= f_mid && f_mid >= f_right) {
        cerr << "Облом ¯\_(ツ)_/¯" << endl;
        return false;
    }
    else {
        //Шаг 4.а)
        if (f_left >= f_mid && f_mid >= f_right) {
            cout << "минитрегольничек = t" << endl;
            delta = t;
            a = x0;
            x_cur = x0 + t;
        }
        //Шаг 4.б)
        else if (f_left <= f_mid && f_mid <= f_right) {
            cout << "минитреугольничек = -t" << endl;
            delta = -t;
            b = x0;
            x_cur = x0 - t;
        }
        k = 1;  

        //Шаг 5 и 6
        while (true) {
            //Шаг 5
            double step_multiplier = pow(2.0, k);
            double x_next = x_cur + step_multiplier * delta;
            //Ищем функцию с новой точкой
            double f_cur = func(x_cur);
            double f_next = func(x_next);
            // Шаг 6.а)
            if (f_next < f_cur) {
                if (delta > 0) {
                    a = x_cur;
                }
                else {
                    b = x_cur;
                }
                x_cur = x_next;
                k++;
            }
            //Шаг 6.б)
            else {
                if (delta > 0) {
                    b = x_next;
                }
                else {
                    a = x_next;
                }
                break;
            }
        }
        return true;
    }
}

double func(double x) {
    return pow(x, 4) + x * x + x + 1;
}
int main() {
    setlocale(LC_ALL, "rus");
    double x0 = -0.4;
    double t = 0.01;
    double a, b;
    cout << "Свенн для f(x) = x^4 + x^2 + x + 1" << endl;
    cout << "x0 = " << x0 << endl;
    cout << "t = " << t << endl;
    if (sven_algorithm(func, x0, t, a, b)) {
        cout << "\nНашли интервал неопределенности: [" << a << ", " << b << "]" << endl;
        cout << "Значения на границах:" << endl;
        cout << "f(" << a << ") = " << func(a) << endl;
        cout << "f(" << b << ") = " << func(b) << endl;
    }
    else {
        cout << "Не удалось найти интервал." << endl;
    }

    return 0;
}
